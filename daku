<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Aftari for Daku 😈</title>

<style>
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:'Segoe UI',sans-serif;
}

body{
    min-height:100vh;
    background:linear-gradient(135deg,#1d2671,#c33764);
    display:flex;
    flex-direction:column;
    align-items:center;
    justify-content:center;
    overflow:hidden;
}

/* 🔥 MAIN TITLE */
.main-title{
    position:absolute;
    top:25px;
    text-align:center;
    color:#fff;
    font-size:28px;
    font-weight:700;
    letter-spacing:1px;
    text-shadow:0 4px 15px rgba(0,0,0,0.4);
}

/* CARD */
.container{
    background:rgba(255,255,255,0.15);
    backdrop-filter:blur(10px);
    padding:30px;
    border-radius:20px;
    text-align:center;
    box-shadow:0 0 30px rgba(0,0,0,0.3);
    width:90%;
    max-width:380px;
}

/* QUESTION */
h1{
    color:#fff;
    margin-bottom:20px;
    animation:float 2s ease-in-out infinite;
    font-size:22px;
}

@keyframes float{
    0%{transform:translateY(0);}
    50%{transform:translateY(-8px);}
    100%{transform:translateY(0);}
}

/* BUTTON AREA */
.buttons{
    position:relative;
    margin-top:25px;
    height:140px;
}

button{
    padding:12px 22px;
    font-size:15px;
    border:none;
    border-radius:30px;
    cursor:pointer;
    position:absolute;
    transition:0.2s;
}

/* YES */
#yesBtn{
    background:#00e676;
    color:#000;
    left:50%;
    transform:translateX(-50%);
}

/* NO */
#noBtn{
    background:#ff5252;
    color:#fff;
    left:20%;
    top:70px;
}

/* RESULT */
.result{
    color:#fff;
    margin-top:20px;
    font-size:18px;
    display:none;
    animation:pop 0.4s ease;
}

@keyframes pop{
    from{transform:scale(0.5);opacity:0;}
    to{transform:scale(1);opacity:1;}
}
</style>
</head>

<body>

<!-- ✅ TITLE -->
<h2 class="main-title">🍽️ Aftari for Daku 😈</h2>

<!-- CARD -->
<div class="container">
    <h1>Kia aap mujhe aftari karwao ge? 😋</h1>

    <div class="buttons" id="btnArea">
        <button id="yesBtn">Haan, aftari karwa doon ga 😄</button>
        <button id="noBtn">Nahi</button>
    </div>

    <div class="result" id="result">
        🎉 Shukriya! Daku bohot khush ho gaya 😎<br>
        Allah apko sawab de 😂
    </div>
</div>

<script>
const noBtn = document.getElementById("noBtn");
const area = document.getElementById("btnArea");
const yesBtn = document.getElementById("yesBtn");
const result = document.getElementById("result");

function moveNoBtn(){
    const areaRect = area.getBoundingClientRect();
    const btnRect = noBtn.getBoundingClientRect();

    const maxX = areaRect.width - btnRect.width;
    const maxY = areaRect.height - btnRect.height;

    const x = Math.random() * maxX;
    const y = Math.random() * maxY;

    noBtn.style.left = x + "px";
    noBtn.style.top = y + "px";
}

noBtn.addEventListener("mouseenter", moveNoBtn);
noBtn.addEventListener("touchstart", moveNoBtn);

yesBtn.addEventListener("click", () => {
    result.style.display = "block";
});
</script>

</body>
</html>
